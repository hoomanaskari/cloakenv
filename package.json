{
  "name": "cloakenv",
  "private": true,
  "version": "1.0.2",
  "description": "Your secrets, invisible to AI. An encrypted local vault for developer secrets.",
  "license": "MIT",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "test": "bun test --recursive",
    "test:core": "bun test packages/core",
    "test:cli": "bun test apps/cli",
    "test:coverage": "bun test --recursive --coverage",
    "dev": "electrobun dev",
    "dev:web": "bun run --filter @cloakenv/web dev",
    "build": "electrobun build",
    "build:prod": "electrobun build --env=stable",
    "build:installers": "bun run release:build",
    "start": "electrobun run",
    "kdf:benchmark": "bun run packages/core/scripts/benchmark-kdf.ts",
    "cli": "bun run apps/cli/src/index.ts",
    "cli:build": "bun run --filter @cloakenv/cli build",
    "cli:build:standalone:darwin-arm64": "bun run --filter @cloakenv/cli build:standalone:darwin-arm64",
    "cli:build:standalone:darwin-x64": "bun run --filter @cloakenv/cli build:standalone:darwin-x64",
    "cli:build:standalone:linux-x64": "bun run --filter @cloakenv/cli build:standalone:linux-x64",
    "cli:build:standalone:windows-x64": "bun run --filter @cloakenv/cli build:standalone:windows-x64",
    "release:build": "bun run src/scripts/release-build.ts",
    "release:assert-tag": "bun run src/scripts/assert-release-tag.ts",
    "release:verify": "bun run src/scripts/verify-release-artifacts.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check packages/ apps/ src/",
    "lint:fix": "bunx biome check --write packages/ apps/ src/"
  },
  "dependencies": {
    "electrobun": "^1.15.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "bun-types": "^1.3.10"
  }
}
