{
  "name": "@cloakenv/varlock-helper",
  "version": "1.0.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src/index.ts"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "cloakenv-varlock": "./dist/cli.js"
  },
  "scripts": {
    "build": "mkdir -p dist && bun build ./src/index.ts ./src/cli.ts --target=node --outdir ./dist"
  },
  "dependencies": {}
}
